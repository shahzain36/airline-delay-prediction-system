#Classification metrics
from sklearn.metrics import confusion_matrix, roc_curve, auc, precision_recall_curve
import matplotlib.pyplot as plt

# Confusion Matrix
cm = confusion_matrix(y_test, y_pred_xgb)
print(f"""
CONFUSION MATRIX:
                Predicted On-Time    Predicted Delayed
Actual On-Time         {cm[0,0]}                  {cm[0,1]}
Actual Delayed         {cm[1,0]}                  {cm[1,1]}

True Negatives (TN):   {cm[0,0]}  ✓ Correctly predicted on-time
False Positives (FP):  {cm[0,1]}  ✗ False alarm (predicted delay, was on-time)
False Negatives (FN):  {cm[1,0]}  ✗ Missed delays (predicted on-time, was delayed)
True Positives (TP):   {cm[1,1]}  ✓ Correctly predicted delayed
""")

# ROC Curve
fpr, tpr, thresholds = roc_curve(y_test, y_pred_proba_xgb)
roc_auc = auc(fpr, tpr)

plt.figure(figsize=(10, 6))
plt.plot(fpr, tpr, color='darkorange', lw=2, label=f'ROC Curve (AUC = {roc_auc:.2f})')
plt.plot([0, 1], [0, 1], color='navy', lw=2, linestyle='--', label='Random Classifier')
plt.xlabel('False Positive Rate')
plt.ylabel('True Positive Rate')
plt.title('ROC Curve - Airline Delay Prediction')
plt.legend(loc="lower right")
plt.savefig('roc_curve.png')
plt.show()

# Precision-Recall Curve
precision, recall, _ = precision_recall_curve(y_test, y_pred_proba_xgb)
pr_auc = auc(recall, precision)

plt.figure(figsize=(10, 6))
plt.plot(recall, precision, color='green', lw=2, label=f'PR Curve (AUC = {pr_auc:.2f})')
plt.xlabel('Recall')
plt.ylabel('Precision')
plt.title('Precision-Recall Curve - Airline Delay Prediction')
plt.legend(loc="lower left")
plt.savefig('pr_curve.png')
plt.show()

# Detailed Metrics
print(f"""
EVALUATION METRICS:
===================
Accuracy:     {accuracy_score(y_test, y_pred_xgb):.4f}
Precision:    {precision_score(y_test, y_pred_xgb):.4f}  (When we predict delay, how often are we correct?)
Recall:       {recall_score(y_test, y_pred_xgb):.4f}    (Of all actual delays, how many did we catch?)
F1-Score:     {f1_score(y_test, y_pred_xgb):.4f}   (Harmonic mean of precision & recall)
ROC-AUC:      {roc_auc_score(y_test, y_pred_proba_xgb):.4f}  (Area under curve - discrimination ability)

Business Impact:
- False Positives (FP): {cm[0,1]:,} flights predicted delayed but were on-time
  → Cost: Unnecessary alerts to passengers


